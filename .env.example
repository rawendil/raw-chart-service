# Server Configuration
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Configuration
# When running via Docker Compose, DB_HOST=postgres and REDIS_URL=redis://redis:6379
# When running locally (npm run dev), DB_HOST=localhost and REDIS_URL=redis://localhost:6379
DB_HOST=postgres
DB_PORT=5432
DB_NAME=rawchart_service
DB_USER=postgres
DB_PASSWORD=password
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# API Key Authentication
API_KEY=your-super-secret-api-key-here

# Logging
LOG_LEVEL=info

# Redis (for caching)
REDIS_URL=redis://redis:6379

# Puppeteer Configuration
CHROMIUM_PATH=/usr/bin/chromium-browser

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Expired-chart cleanup
# Periodically deletes charts whose expires_at has passed, freeing DB space.
EXPIRED_CHART_CLEANUP_ENABLED=true         # set to 'false' to disable the cleanup entirely
EXPIRED_CHART_CLEANUP_INTERVAL_MS=3600000  # how often the sweep runs (default 1h)
EXPIRED_CHART_RETENTION_MS=0               # grace period after expires_at before deletion; 0 = delete immediately